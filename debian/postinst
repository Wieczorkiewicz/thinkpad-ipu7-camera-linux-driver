#!/bin/bash
set -e

case "$1" in
    configure)
        # Auto-detect the primary human user (uid 1000–60000, with a login shell)
        PRIMARY_USER=$(getent passwd \
            | awk -F: '$3 >= 1000 && $3 < 60000 && $7 !~ /nologin|false|sync/ {print $1; exit}')

        if [ -n "$PRIMARY_USER" ]; then
            PRIMARY_UID=$(id -u "$PRIMARY_USER")
            # Only rewrite if the file still has the default placeholder values
            if grep -q '^PIPEWIRE_RUNTIME_DIR=/run/user/1000$' /etc/default/ipu7-camera 2>/dev/null \
               && [ "$PRIMARY_UID" != "1000" ]; then
                sed -i \
                    -e "s|^PIPEWIRE_RUNTIME_DIR=.*|PIPEWIRE_RUNTIME_DIR=/run/user/$PRIMARY_UID|" \
                    /etc/default/ipu7-camera
            fi
        fi

        # Load / reload v4l2loopback with the modprobe options from the package
        if lsmod | grep -q v4l2loopback; then
            systemctl stop ipu7-camera-dynamic 2>/dev/null || true
            modprobe -r v4l2loopback 2>/dev/null || true
        fi
        modprobe v4l2loopback 2>/dev/null || true

        # Reload udev rules so video32 gets uaccess and video30/31 get hidden
        udevadm control --reload-rules 2>/dev/null || true
        udevadm trigger --subsystem-match=video4linux 2>/dev/null || true
        ;;
esac

#DEBHELPER#
